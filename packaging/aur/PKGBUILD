# Maintainer: Brandon Hall <brandon@brandonhall.us>
pkgname=mox-tmux
_upstream=mox
pkgver=0.5.2
pkgrel=1
pkgdesc='CLI for creating and managing tmux sessions declaratively from YAML config'
arch=('x86_64' 'aarch64')
url='https://github.com/bthall/mox'
license=('MIT')
depends=('tmux')
makedepends=('go')
source=("$_upstream-$pkgver.tar.gz::https://github.com/bthall/mox/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('bfdf06351cd89b3c576cca9c76e0a71cff26c38891d13540f634db3f057ed1ac')

build() {
    cd "$_upstream-$pkgver"
    export CGO_ENABLED=0
    export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
    go build \
        -ldflags="-X github.com/bthall/mox/pkg/version.Version=v$pkgver" \
        -o mox ./cmd/mox
}

check() {
    cd "$_upstream-$pkgver"
    go test ./...
}

package() {
    cd "$_upstream-$pkgver"
    install -Dm755 mox "$pkgdir/usr/bin/mox"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
